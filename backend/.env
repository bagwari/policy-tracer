# ─── Server ──────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
LOG_LEVEL=info
CORS_ORIGIN=http://localhost:5173

# ─── Ollama (Open-Source LLM) ─────────────────────────────────────────────────
# 1. Install: https://ollama.ai
# 2. Pull model: ollama pull llama3.2
# 3. It auto-starts on macOS or run: ollama serve
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_TIMEOUT_MS=120000

# ─── MongoDB ──────────────────────────────────────────────────────────────────
# Local:  MONGO_URI=mongodb://localhost:27017/policy_tracer
MONGO_URI=mongodb+srv://user:pass@cluster0.xxxx.mongodb.net/policy_tracer

# ─── AWS CloudWatch ───────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=***
AWS_SECRET_ACCESS_KEY=***
# AWS_SESSION_TOKEN=     # if using temporary credentials

# For LocalStack local dev:
# AWS_ENDPOINT_OVERRIDE=http://localhost:4566

# CloudWatch Log Groups to search (comma-separated)
# /aws/lambda/policy-service is auto-created by the Lambda deployment
CW_LOG_GROUPS=/aws/lambda/policy-service,/aws/ecs/policy-processor,/app/policy-api

# ─── Lambda Policy Tool (optional) ────────────────────────────────────────────
# Set this after running: cd lambda && ./deploy.sh
# When set, policy tool calls go to Lambda (generates real CW logs) instead of
# hitting MongoDB directly from the local agent.
POLICY_LAMBDA_URL=

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=30

{
  "name": "policy-tracer-backend",
  "version": "1.0.0",
  "description": "Agentic AI Policy & CloudWatch Tracer — Backend API",
  "type": "module",
  "engines": { "node": ">=22.0.0" },
  "scripts": {
    "dev":   "tsx watch src/server.ts",
    "build": "tsc --project tsconfig.build.json",
    "start": "node dist/server.js",
    "seed":  "tsx src/db/seed.ts",
    "lint":  "eslint src --ext .ts"
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch-logs": "^3.600.0",
    "cors":                "^2.8.5",
    "dotenv":              "^16.4.5",
    "express":             "^4.19.2",
    "express-rate-limit":  "^7.3.1",
    "helmet":              "^7.1.0",
    "mongoose":            "^8.5.1",
    "morgan":              "^1.10.0",
    "ollama":              "^0.5.9",
    "uuid":                "^10.0.0",
    "winston":             "^3.13.0",
    "zod":                 "^3.23.8"
  },
  "devDependencies": {
    "@types/cors":         "^2.8.17",
    "@types/express":      "^4.17.21",
    "@types/morgan":       "^1.9.9",
    "@types/node":         "^22.0.0",
    "@types/uuid":         "^10.0.0",
    "tsx":                 "^4.16.0",
    "typescript":          "^5.5.3"
  }
}
